{
  "name": "noue-tiktok-dash",
  "private": true,
  "version": "0.1.0",
  "description": "Dashboard de análise de UGC / TikTok Shop (Nouè) — Top 30, transcrição, análise de IA e geração de roteiros.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "dotenv -e .env -- npm run dev -w web",
    "dev:web": "dotenv -e .env -- npm run dev -w web",
    "worker": "dotenv -e .env -- npm run start -w worker",
    "worker:dev": "dotenv -e .env -- npm run dev -w worker",
    "build": "npm run db:generate && npm run build -w web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:local": "node dev/pglite-server.mjs",
    "db:generate": "npm run generate -w @noue/db",
    "db:push": "dotenv -e .env -- npm run push -w @noue/db",
    "db:migrate": "dotenv -e .env -- npm run migrate -w @noue/db",
    "db:seed": "dotenv -e .env -- npm run seed -w @noue/db",
    "db:studio": "dotenv -e .env -- npm run studio -w @noue/db"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@electric-sql/pglite-socket": "^0.2.7",
    "dotenv-cli": "^11.0.0"
  }
}
