# ─────────────────────────────────────────────────────────────
# Nouè TikTok Dash — variáveis de ambiente (copie para .env)
# ─────────────────────────────────────────────────────────────

# ─── Banco de dados (Postgres) ───
# DEV LOCAL (padrão): use `npm run db:local` (Postgres embutido PGlite na porta 5432).
#   Precisa de pgbouncer=true (PGlite usa conexão única).
# PRODUÇÃO: troque pela URL do Supabase/Neon. Ex. Supabase:
#   postgresql://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/postgres?connection_limit=1&pgbouncer=true"
# DIRECT_URL: usada em migrations. No Supabase, use a conexão direta (porta 5432, sem pooler).
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/postgres?connection_limit=1"

# ─── Web (apps/web) ───
NEXT_PUBLIC_APP_NAME="Nouè UGC Dashboard"
# URL pública do worker (para o dashboard disparar reprocessamento). Opcional.
WORKER_URL="http://localhost:8080"

# ─── Autenticação (allowlist simples de e-mails, separado por vírgula) ───
AUTH_ALLOWED_EMAILS=""

# ─── Storage de mídia (Cloudflare R2 — S3 compatible) ───
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="noue-ugc"
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
# Base pública opcional (se o bucket tiver domínio público). Senão usamos URL assinada.
R2_PUBLIC_BASE_URL=""

# ─── Gemini (Google AI Studio) ───
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# ─── Ingestão de dados ───
# csv = importar relatório do Affiliate Center | tiktok_api = API oficial (quando aprovada)
INGEST_SOURCE="csv"

# ─── TikTok Shop Open Platform (preencher quando o app for aprovado) ───
TIKTOK_APP_KEY=""
TIKTOK_APP_SECRET=""
TIKTOK_SHOP_CIPHER=""
TIKTOK_ACCESS_TOKEN=""

# ─── Worker (apps/worker) ───
# Proxy residencial opcional para o yt-dlp (evita bloqueio de IP de datacenter)
DOWNLOAD_PROXY_URL=""
# Modelo whisper.cpp: tiny | base | small | medium
WHISPER_MODEL="small"
# Intervalo do loop da fila (ms)
WORKER_POLL_MS="5000"
